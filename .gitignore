# -----------------------------------------------------------------------------
# devenv / direnv / Nix local state
# -----------------------------------------------------------------------------
# devenv runtime state, eval output, task state, etc.
.devenv/

# direnv cache
.direnv/

# Nix build outputs and local symlinks
result
result-*

# Generated by git-hooks.nix / devenv hooks wiring.
.pre-commit-config.yaml

# Local-first polyrepo workflow: avoid lockfile churn unless a repo explicitly
# wants to commit this.
devenv.lock

# Local override conventions used across poly repos.
*.local.*
*.override.*
!*.local.example.*
!*.override.example.*

# -----------------------------------------------------------------------------
# devenv-materialized config symlinks
# -----------------------------------------------------------------------------
# These are materialized into consumer repos for editor / tool discovery.
# The real source of truth lives in poly modules, not in the consumer repo.
.cargo/
rust-toolchain.toml
rustfmt.toml

# Managed Cargo: generated from Cargo.poly.toml + shared catalog.
# Keep this ignored only in repos that opt into managed Cargo generation.
/Cargo.toml

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
# Cargo / rustc build output
target/

# Benchmark / profiling output commonly produced locally
flamegraph.svg
*.profraw
*.profdata

# -----------------------------------------------------------------------------
# Node / TypeScript
# -----------------------------------------------------------------------------
node_modules/

# Package manager caches / local installs
.npm/
.pnpm-store/
.yarn/
.yarn-cache/

# Common framework / bundler outputs
dist/
build/
.next/
.nuxt/
.svelte-kit/
.parcel-cache/
.turbo/
coverage/

# TypeScript incremental build state
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Virtualenvs
.venv/
venv/
env/

# Bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# Packaging / test outputs
htmlcov/
.coverage
.coverage.*
.eggs/
*.egg-info/
pip-wheel-metadata/

# Jupyter
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Secrets / machine-local env files
# -----------------------------------------------------------------------------
# Keep examples tracked; ignore actual machine-local env files.
.env
.env.*
!.env.example
!.env.*.example
!.envrc

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
.playwright-cli/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
tmp/
